  "author": "Homayoun Mohammadi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/homayounmmdy/svg-world-maps.git"
  },
  "bugs": {
    "url": "https://github.com/homayounmmdy/svg-world-maps/issues"
  },
  "homepage": "https://github.com/homayounmmdy/svg-world-maps#readme"
}
