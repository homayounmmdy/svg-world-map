{
  "name": "svg-world-maps",
  "version": "0.4.0",
  "description": "World map SVG for any JavaScript framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "src/maps/optional/**/*.ts",
    "scripts/add-map.js"
  ],
  "bin": {
    "add-map": "./scripts/add-map.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
